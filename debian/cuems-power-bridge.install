# Ship default config under /usr/share for postinst-time copy + as
# package-data fallback inside the venv.
src/cuemspowerbridge/data/power-bridge.conf.default usr/share/cuems/
src/cuemspowerbridge/data/shelly-mjs/cuems-shutdown.js usr/share/cuems/shelly-mjs/

# Operator CLI shims on PATH. The actual entries live in the venv at
# /usr/lib/cuems/bin/; these /usr/bin/ wrappers just exec them so
# operators can run the tools without `/usr/lib/cuems/bin/` on PATH.
data/bin/cuems-power-bridge usr/bin/
data/bin/cuems-power-bridge-deploy-keys usr/bin/
data/bin/cuems-power-bridge-install-mjs usr/bin/
data/bin/cuems-power-bridge-test-projector usr/bin/
